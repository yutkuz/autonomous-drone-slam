      <link name="east"><pose>8 0 1.4 0 0 0</pose><collision name="c"><geometry><box><size>0.18 10 2.8</size></box></geometry></collision><visual name="v"><geometry><box><size>0.18 10 2.8</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/PaintedWall</name></script></material></visual></link>
      <link name="west"><pose>-6 0 1.4 0 0 0</pose><collision name="c"><geometry><box><size>0.18 10 2.8</size></box></geometry></collision><visual name="v"><geometry><box><size>0.18 10 2.8</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/CeilingTiled</name></script></material></visual></link>
    </model>

