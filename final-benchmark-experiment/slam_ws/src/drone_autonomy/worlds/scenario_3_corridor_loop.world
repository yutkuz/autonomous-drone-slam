      <link name="center_block_n"><pose>1 1.2 1.25 0 0 0</pose><collision name="c"><geometry><box><size>6.0 0.18 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>6.0 0.18 2.5</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material></visual></link>
