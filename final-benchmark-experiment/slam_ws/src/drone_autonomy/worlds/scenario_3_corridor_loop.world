      <link name="red_marker"><pose>-4.8 3.0 0.7 0 0 0</pose><collision name="c"><geometry><box><size>0.5 0.5 1.4</size></box></geometry></collision><visual name="v"><geometry><box><size>0.5 0.5 1.4</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Red</name></script></material></visual></link>
      <link name="blue_marker"><pose>6.5 3.1 0.65 0 0 0</pose><collision name="c"><geometry><cylinder><radius>0.28</radius><length>1.3</length></cylinder></geometry></collision><visual name="v"><geometry><cylinder><radius>0.28</radius><length>1.3</length></cylinder></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Blue</name></script></material></visual></link>
