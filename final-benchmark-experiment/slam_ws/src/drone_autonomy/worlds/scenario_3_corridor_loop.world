<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="scenario_3_corridor_loop">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <model name="floor"><static>true</static><pose>1 0 0.005 0 0 0</pose><link name="link">
      <collision name="c"><geometry><box><size>14 10 0.01</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>14 10 0.01</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material></visual>
