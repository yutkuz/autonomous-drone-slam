      <link name="center_block_e"><pose>4 0 1.25 0 0 0</pose><collision name="c"><geometry><box><size>0.18 2.4 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>0.18 2.4 2.5</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Residential</name></script></material></visual></link>
      <link name="center_block_w"><pose>-2 0 1.25 0 0 0</pose><collision name="c"><geometry><box><size>0.18 2.4 2.5</size></box></geometry></collision><visual name="v"><geometry><box><size>0.18 2.4 2.5</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/PaintedWall</name></script></material></visual></link>
